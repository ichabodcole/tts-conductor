{
  "name": "@alien-lobster-buffet/tts-conductor-core",
  "version": "0.3.0-alpha.0",
  "description": "Core utilities for parsing, chunking, and assembling TTS audio",
  "keywords": [
    "tts",
    "text-to-speech",
    "audio",
    "orchestration"
  ],
  "license": "MIT",
  "author": "Cole Reed <alienlobsterbuffet.dev@gmail.com>",
  "homepage": "https://github.com/ichabodcole/tts-conductor#readme",
  "bugs": {
    "url": "https://github.com/ichabodcole/tts-conductor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ichabodcole/tts-conductor.git",
    "directory": "packages/tts-core"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepublishOnly": "tsdown",
    "test": "vitest --run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "execa": "^9.6.0",
    "ffmpeg-static": "^5.2.0"
  }
}
