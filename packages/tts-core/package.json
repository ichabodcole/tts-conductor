{
  "name": "@tts-conductor/core",
  "version": "1.1.0",
  "description": "Core utilities for parsing, chunking, and assembling TTS audio",
  "keywords": [
    "tts",
    "text-to-speech",
    "audio",
    "orchestration"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "tsdown --clean",
    "dev": "tsdown --watch",
    "test": "vitest --run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "execa": "^9.6.0",
    "ffmpeg-static": "^5.2.0"
  }
}
