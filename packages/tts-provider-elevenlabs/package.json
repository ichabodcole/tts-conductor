{
  "name": "@tts-conductor/provider-elevenlabs",
  "version": "1.1.0",
  "description": "ElevenLabs provider bindings for the TTS Conductor ecosystem",
  "keywords": [
    "tts",
    "elevenlabs",
    "provider"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "tsdown --clean",
    "dev": "tsdown --watch",
    "test": "vitest --run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tts-conductor/core": "workspace:*"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.49.0"
  },
  "devDependencies": {
    "@tts-conductor/core": "workspace:^"
  }
}
