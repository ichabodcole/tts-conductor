{
  "name": "tts-conductor",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for TTS core orchestration and provider packages",
  "keywords": [
    "tts",
    "text-to-speech",
    "monorepo",
    "bun",
    "turbo"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "ffmpeg-static"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "verify": "bun run format:check && bun run typecheck && bun run lint && bun run test",
    "prune-branches": "git branch --merged | grep -vE '^[*]|main$|develop$' | xargs -r git branch -d",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.6.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsdown": "^0.16.6",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
