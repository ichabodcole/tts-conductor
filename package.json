{
  "name": "tts-conductor",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for TTS core orchestration and provider packages",
  "keywords": [
    "tts",
    "text-to-speech",
    "monorepo",
    "bun",
    "turbo"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "ffmpeg-static"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write --error-on-warnings .",
    "format": "biome format --write .",
    "format:md": "prettier --write '**/*.md'",
    "clean": "turbo run clean",
    "check": "turbo run typecheck && biome check --error-on-warnings . && turbo run test",
    "verify": "bun run check",
    "prune-branches": "git branch --merged | grep -vE '^[*]|main$|develop$' | xargs -r git branch -d",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,json,jsonc}": [
      "biome check --write --error-on-warnings --no-errors-on-unmatched"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.6.2",
    "tsdown": "^0.22.0",
    "turbo": "^2.6.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
